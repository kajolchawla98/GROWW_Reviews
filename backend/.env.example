# ── GROWW AI Product Intelligence Copilot ──
# Copy this file to .env and fill in your values

# App
DEBUG=true

# Google Play Store
GROWW_APP_ID=com.nextbillion.groww
REVIEW_WEEKS=4
REVIEW_LANGUAGE=en
REVIEW_COUNTRY=in
MAX_REVIEWS=1000
MIN_WORD_COUNT=6

# Database (SQLite for dev, PostgreSQL for prod)
# DATABASE_URL=sqlite:///./data/groww_copilot.db
# DATABASE_URL=postgresql://user:password@localhost:5432/groww_copilot

# ── Groq (LLM) ──
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile

# Groq rate limits (free tier defaults — adjust for your plan)
GROQ_RPM=28
GROQ_RPD=14000
GROQ_TPM=5500

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=groww_reviews

# Pipeline
BATCH_SIZE=50
LLM_BATCH_SIZE=25

# Phase 5: Publishing (Google Docs & Gmail via MCP Server)
MCP_SERVER_URL=https://saksham-mcp-server-production-0909.up.railway.app
PUBLISH_DOC_ID=your_google_doc_id
PUBLISH_EMAIL_TO=pm-team@groww.in
